# DevGenie frontend — local environment.
# Copy to `.env.local` (which is git-ignored) and fill in the four values.
#
#   cp frontend/.env.local.example frontend/.env.local
#
# NextAuth reads these at request time; Next.js loads them automatically.

# ---- GitLab OAuth ---------------------------------------------------------
# Create an OAuth application at:
#   https://gitlab.com/-/user_settings/applications
# Settings:
#   - Name:            DevGenie dev (anything works)
#   - Redirect URI:    http://localhost:3737/api/auth/callback/gitlab
#   - Confidential:    YES (checked)
#   - Scopes:          read_api  read_user
# Save, then paste the Application ID and Secret here.
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# ---- NextAuth ------------------------------------------------------------
# Random 32+ byte secret used to sign JWT session cookies.
# Generate one with:    openssl rand -base64 32
NEXTAUTH_SECRET=
# The base URL the browser sees. Localhost for dev, your deployed URL in prod.
NEXTAUTH_URL=http://localhost:3737

# ---- Backend wiring -------------------------------------------------------
# Where the FastAPI backend (ui/main.py) is reachable. Default below assumes
# `uvicorn ui.main:app --port 8001` running on the same machine.
BACKEND_URL=http://127.0.0.1:8001
