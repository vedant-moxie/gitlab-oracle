# ---- Google Cloud ----
GOOGLE_CLOUD_PROJECT=autodev-agent
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# ---- GitLab ----
GITLAB_URL=https://gitlab.com
# Project to INGEST from (the rich UPSTREAM project: commits + MRs + issues + notes)
GITLAB_UPSTREAM_PROJECT=group/upstream-repo
# Your FORK where the live demo MR is opened and the Oracle posts comments
GITLAB_FORK_PROJECT=your-username/your-fork
# PAT with read_api, read_repository (+ api/write for posting comments on the fork)
# Stored in Secret Manager as 'gitlab-pat' in production; .env is local-dev only.
GITLAB_PAT=glpat-xxxxxxxxxxxxxxxxxxxx

# ---- Vertex AI Vector Search ----
VECTOR_INDEX_ID=
VECTOR_INDEX_ENDPOINT_ID=
VECTOR_DEPLOYED_INDEX_ID=gitlab_oracle_deployed
EMBEDDING_MODEL=text-embedding-005
EMBEDDING_DIM=768

# ---- Firestore (graph/metadata) ----
FIRESTORE_DATABASE=(default)

# ---- Webhook ----
GITLAB_WEBHOOK_SECRET=change-me-strong-random

# ---- Notifications ----
# Optional: Incoming Webhook URL to post MR warnings to Slack
SLACK_WEBHOOK_URL=
